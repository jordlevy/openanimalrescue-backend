# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# go.sum should be committed
!go.sum

# CDK asset staging directory
.cdk.staging
cdk.out

# Exclude all files in the bin directory
openanimalrescue-api/bin/**

# Include specific files named bootstrap in the bin directory and its subdirectories
!openanimalrescue-api/bin/**/bootstrap
